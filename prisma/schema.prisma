generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Notice {
  seq_notice_id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model User {
  seq_user_id        Int      @id @default(autoincrement())
  user_id     String
  user_password   String
  createdAt DateTime @default(now())
}
