generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Notice {
  seq_notice_id Int      @id @default(autoincrement())
  title         String
  seq_content   Int?
  src           String?
  img_seq_one   Int?
  img_seq_two   Int?
  img_seq_three Int?
  img_seq_fore  Int?
  img_seq_five  Int?
  tech_stack    String?
  createdAt     DateTime @default(now())
  contents      Content[]
  images        Notice_img[]

  @@map("TBL_NOTICE")
}

model Content {
  seq_content Int    @id @default(autoincrement())
  seq_notice  Int
  title       String
  content     String

  notice      Notice @relation(fields: [seq_notice], references: [seq_notice_id])

  @@index([seq_notice])
  @@map("TBL_CONTENT")
}

model Notice_img {
  seq_notice_img_id Int    @id @default(autoincrement())
  notice_id         Int
  img_name          String?
  img_title         String?
  src               String?

  notice            Notice @relation(fields: [notice_id], references: [seq_notice_id])

  @@map("TBL_NOTICE_IMG")
}

model User {
  seq_user_id       Int           @id @default(autoincrement())
  username          String        @unique
  email             String        @unique
  password_hash     String?
  user_role         String        @default("USER")
  display_name      String?
  email_verified_at DateTime?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  auth_accounts     AuthAccount[]

  @@map("TBL_USER")
}

model AuthAccount {
  seq_auth_account_id Int      @id @default(autoincrement())
  seq_user_id         Int
  provider            String
  provider_account_id String
  provider_email      String?
  access_token        String?  @db.Text
  refresh_token       String?  @db.Text
  expires_at          Int?
  token_type          String?
  scope               String?
  id_token            String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user                User     @relation(fields: [seq_user_id], references: [seq_user_id], onDelete: Cascade)

  @@unique([provider, provider_account_id], map: "UQ_AUTH_PROVIDER_ACCOUNT")
  @@index([seq_user_id])
  @@map("TBL_AUTH_ACCOUNT")
}
